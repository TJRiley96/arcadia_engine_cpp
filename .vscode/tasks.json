{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "CMake: Configure (Debug)",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--preset",
                "debug-linux-x64"
            ],
            "windows": {
                "args": [
                    "--preset",
                    "debug-windows-x64"
                ],
                "options": {
                    "env": {
                        "PATH": "C:\\msys64\\ucrt64\\bin;C:\\msys64\\ucrt64\\lib;C:\\msys64\\usr\\bin;${env:PATH}"
                    }
                }
            },
            "problemMatcher": []
        },
        {
            "label": "CMake: Build (Debug)",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build",
                "--preset",
                "build-debug-linux-x64"
            ],
            "windows": {
                "args": [
                    "--build",
                    "--preset",
                    "build-debug-windows-x64"
                ],
                "options": {
                    "env": {
                        "PATH": "C:\\msys64\\ucrt64\\bin;C:\\msys64\\ucrt64\\lib;C:\\msys64\\usr\\bin;${env:PATH}"
                    }
                }
            },
            "dependsOn": "CMake: Configure (Debug)",
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            }
        }
    ]
}